# ── App ──
APP_NAME=FinControl
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# ── Backend ──
BACKEND_PORT=8000
BACKEND_WORKERS=1

# ── Database ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fincontrol
POSTGRES_USER=fincontrol
POSTGRES_PASSWORD=change-me-in-production

# Constructed by backend from above vars:
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Service ──
ML_SERVICE_URL=http://ml-service:8001
ML_CATEGORIZATION_THRESHOLD=0.85

# ── ML Service (puerto expuesto) ──
ML_SERVICE_PORT=8001

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Frontend ──
FRONTEND_PORT=3000
# URL del backend accesible desde el browser del host (no desde dentro de Docker)
VITE_API_URL=http://localhost:8000
